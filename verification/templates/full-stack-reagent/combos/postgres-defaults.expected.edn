{:db       :postgres
 :features {:content true :ssr true :markdownc true :auth true}
 :name     "my-app"

 :must-exist     ["src/clj/my_app/main.clj"
                  "src/clj/my_app/config.clj"
                  "src/clj/my_app/content/core.clj"
                  "src/clj/my_app/ssr/prerender.clj"
                  "src/clj/my_app/auth/user.clj"
                  "src/clj/my_app/auth/user/web.clj"
                  "src/cljc/my_app/schema/full.cljc"
                  "src/cljc/my_app/schema/bg_task.cljc"
                  "src/cljc/my_app/schema/user.cljc"
                  "src/cljc/my_app/markdownc.cljc"
                  "src/cljs/my_app/main.cljs"
                  "src/cljs/my_app/auth/user.cljs"
                  "src/cljs/my_app/auth/forgot_password.cljs"
                  "src/cljs/my_app/auth/recover_password.cljs"
                  "src/cljs/my_app/content/page.cljs"
                  "dev/my_app/seed.clj"
                  "content/blog"
                  "package.json"
                  "bin/db"
                  "deps.edn"
                  "LICENSE"
                  "README.md"]

 :must-not-exist ["bin/db.template.memory"
                  "bin/db.template.sqlite"
                  "bin/db.template.postgres"
                  "bin/db.template.datomic-pro"
                  "c3kit-template.edn"
                  "c3kit-template.bb"
                  "README.scaffold.md"
                  ".c3kit-jig-context.edn"
                  ;; legacy schema paths removed
                  "src/cljc/my_app/schema.cljc"
                  "src/cljc/my_app/bg_task.cljc"
                  "src/cljc/my_app/auth/user/schema.cljc"]

 :file-contains  {"src/clj/my_app/config.clj"  ["postgres-local"
                                                ":bucket postgres-local"
                                                "MyApp"]
                  "src/clj/my_app/main.clj"    ["my-app.content.core"
                                                "my-app.ssr.prerender"
                                                "my-app.auth.user.web"]
                  "deps.edn"                   ["com.cleancoders.c3kit/apron"
                                                "org.mindrot/jbcrypt"
                                                "markdown-to-hiccup"
                                                "org.postgresql/postgresql"
                                                "my-app.compile-cljs"]
                  "bin/db"                     ["createdb"]
                  "src/cljs/my_app/config.cljs" ["ws-csrf-token"]
                  "dev/my_app/repl.clj"         ["config-from-service"
                                                 "-ensure-migration-schema!"]}

 :file-not-contains {"src/clj/my_app/config.clj" ["datomic-local"
                                                  "sqlite-local"
                                                  "replaced by line below at scaffold"
                                                  "acme.schema/full"
                                                  "acme.bg-task"
                                                  "acme.auth.user.schema"]
                     "src/clj/my_app/main.clj"   ["acme.schema/full"
                                                  "acme.bg-task"
                                                  "acme.auth.user.schema"
                                                  "#_bg-tasks"]
                     "deps.edn"                   ["my.datomic.com"
                                                   "aws-java-sdk"
                                                   "@c3kit/"
                                                   "acme.schema/full"
                                                   "acme.bg-task"
                                                   "acme.auth.user.schema"]
                     "dev/my_app/seed.clj"        ["(prn \"other-fields: "
                                                   "(prn \"e: "]}}
