{:db       :memory
 :features {:content true :ssr true :markdownc true :auth true :websocket false}
 :name     "my-app"

 :must-exist     ["src/clj/my_app/main.clj"
                  "src/clj/my_app/config.clj"
                  "src/cljc/my_app/schema/full.cljc"
                  "src/cljc/my_app/schema/bg_task.cljc"
                  "src/cljc/my_app/schema/user.cljc"
                  "src/cljs/my_app/main.cljs"
                  "src/cljs/my_app/auth/user.cljs"
                  "src/cljs/my_app/forms.cljs"
                  "bin/db"
                  "deps.edn"
                  "LICENSE"
                  "README.md"]

 :must-not-exist ["c3kit-template.edn"
                  "c3kit-template.bb"
                  "README.scaffold.md"
                  ".c3kit-jig-context.edn"
                  ;; legacy schema paths removed
                  "src/cljc/my_app/schema.cljc"
                  "src/cljc/my_app/bg_task.cljc"
                  "src/cljc/my_app/auth/user/schema.cljc"]

 :file-contains  {"src/clj/my_app/config.clj"        ["memory-local"
                                                      ":bucket memory-local"
                                                      "MyApp"]
                  "src/clj/my_app/main.clj"          ["my-app.content.core"
                                                      "my-app.auth.user.web"]
                  "src/cljs/my_app/auth/user.cljs"   ["install-and-connect!"
                                                      "data-fetched?"]
                  "src/cljs/my_app/forms.cljs"       ["attempt-submit"
                                                      "ajax/post!"]
                  "deps.edn"                         ["my-app.compile-cljs"]
                  "dev/my_app/repl.clj"              ["config-from-service"
                                                      "-ensure-migration-schema!"]}

 :file-not-contains {"src/clj/my_app/main.clj"            ["c3kit.wire.websocket"
                                                           "websocket/service"
                                                           "acme.schema/full"
                                                           "acme.bg-task"
                                                           "acme.auth.user.schema"
                                                           "#_bg-tasks"]
                     "src/clj/my_app/config.clj"          ["acme.schema/full"
                                                           "acme.bg-task"
                                                           "acme.auth.user.schema"]
                     "src/cljs/my_app/auth/user.cljs"   ["c3kit.wire.websocket"
                                                         "ws/start!"
                                                         "ws/call!"]
                     "src/cljs/my_app/forms.cljs"       ["c3kit.wire.websocket"
                                                         "ws/call!"]
                     "src/cljs/my_app/config.cljs"      ["ws-csrf-token"]
                     "deps.edn"                          ["acme.schema/full"
                                                          "acme.bg-task"
                                                          "acme.auth.user.schema"]
                     "dev/my_app/seed.clj"              ["(prn \"other-fields: "
                                                         "(prn \"e: "]}}
