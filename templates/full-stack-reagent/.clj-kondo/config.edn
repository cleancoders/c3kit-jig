;; clj-kondo configuration shipped with the scaffolded project.
;;
;; The verification harness runs `clj-kondo --lint src spec dev` WITHOUT
;; classpath/dependency analysis and requires ZERO findings (clj-kondo exits
;; non-zero on ANY warning/error). The settings below silence library-macro
;; and c3kit-idiom false positives that clj-kondo cannot resolve without
;; analysing the deps, plus a few linters that are noise on a generated
;; skeleton (e.g. placeholder bindings in component signatures). They affect
;; linting only — not compiled behaviour.
{:lint-as
 {;; c3kit's `for-all` is a comprehension macro shaped like `for`.
  c3kit.apron.corec/for-all clojure.core/for
  ;; garden's `defstyles` defines the stylesheet var; treat like `def`.
  garden.def/defstyles      clojure.core/def}

 :linters
 {;; c3kit specs and garden style namespaces use `(:require [x :refer :all])`
  ;; deliberately.
  :refer-all           {:level :off}
  ;; speclj's whole DSL is referred but used only inside describe/it bodies
  ;; clj-kondo can't resolve without jar analysis.
  :unused-referred-var {:level :off}
  :unused-namespace    {:level :off}
  ;; speclj `:refer` lists occasionally repeat a symbol; harmless.
  :duplicate-require   {:level :off}
  ;; Generated skeleton has placeholder bindings (reagent component args,
  ;; destructured config) and handler vars referenced via runtime symbols.
  :unused-binding      {:level :off}
  :unused-value        {:level :off}
  :unused-import       {:level :off}
  :unresolved-var      {:level :off}

  ;; The router uses c3kit `lazy-routes`, which references handler namespaces
  ;; as fully-qualified symbols that are intentionally NOT required (lazy load
  ;; to avoid eager dependency cycles). They resolve at runtime.
  :unresolved-namespace
  {:exclude [acme.security.csp
             acme.content.core
             acme.auth.user.api
             acme.auth.user.ajax
             acme.auth.user.web
             acme.auth.destination
             acme.layouts
             acme.errors
             acme.version
             acme.sandbox.core]}

  ;; speclj + secretary + project test-helper macros referred via `:refer :all`
  ;; / `:require-macros` can't be resolved without jar analysis, so their
  ;; structure forms, assertion macros, stub helpers, secretary `defroute`
  ;; route-param bindings, and the project's `it-routes` helper read as
  ;; unresolved. Symbol-resolution only.
  :unresolved-symbol
  {:exclude [;; speclj structure
             describe context it xit
             before before-all after after-all around around-all with with-all
             focus-describe focus-context focus-it
             tags pending
             ;; speclj assertions
             should should-not should= should-not= should== should-not==
             should-be should-not-be should-be-a should-not-be-a
             should-be-nil should-not-be-nil should-fail
             should-contain should-not-contain
             should-start-with should-not-start-with
             should-end-with should-not-end-with
             should-throw should-not-throw
             should-have-invoked should-not-have-invoked
             should-invoke should-not-invoke
             should-be-same should-not-be-same
             should< should<= should> should>=
             ;; speclj stubs / fixtures
             stub with-stubs redefs-around -fail -to-s
             ;; project + c3kit.wire test helpers (spec-helper macros)
             it-routes capture-logs
             should-be-ajax-ok should-be-ajax-fail
             should-have-invoked-ajax-get should-have-invoked-ajax-post
             should-have-invoked-ws
             should-select should-not-select
             ;; secretary defroute route-param bindings (bound by URL pattern)
             recovery-token content-type permalink sandbox-page]}}}
