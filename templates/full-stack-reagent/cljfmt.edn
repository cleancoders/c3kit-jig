;; cljfmt configuration shipped with the scaffolded project.
;;
;; The scaffolder runs cljfmt with this config as the final step of
;; rendering — i.e. against the stripped output, not the marker-laden
;; template — so cljfmt's full ruleset is safe and the scaffold is born
;; formatted. The verification harness then runs `cljfmt check src spec dev`
;; against the same files with the same config, which is a no-op verification.
;;
;; :extra-indents register block-style indentation for the speclj test macros
;; so cljfmt does not align spec bodies under the first argument (which would
;; fight speclj's conventional 2-space body indentation used throughout).
{:extra-indents
 {describe      [[:block 1]]
  context       [[:block 1]]
  it            [[:block 1]]
  xit           [[:block 1]]
  before        [[:block 0]]
  before-all    [[:block 0]]
  after         [[:block 0]]
  after-all     [[:block 0]]
  around        [[:block 1]]
  with          [[:block 1]]
  with-all      [[:block 1]]
  redefs-around [[:block 1]]
  it-routes     [[:block 2]]}}
