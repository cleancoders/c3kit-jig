{:paths ["src" "spec"]
 :deps  {dev.weavejester/cljfmt {:mvn/version "0.16.4"}
         org.clojure/tools.cli  {:mvn/version "1.1.230"}
         speclj/speclj          {:mvn/version "3.12.0"}}
 :tasks
 {c3kit-jig {:doc      "Run the CLI from source. e.g. bb c3kit-jig create my-app"
             :requires ([c3kit-jig.main]
                        [babashka.fs :as bfs])
             :task     (let [dir-with-templates? (fn [d]
                                                   (and (bfs/exists? d)
                                                        (some (fn [sub] (and (bfs/directory? sub)
                                                                             (bfs/exists? (bfs/path sub "c3kit-template.edn"))))
                                                              (bfs/list-dir d))))
                             default-dir         (first (filter dir-with-templates?
                                                                ["../templates" "test-fixtures"]))
                             args                *command-line-args*
                             user-set?           (or (System/getenv "C3KIT_TEMPLATES")
                                                     (some (fn [a] (= a "--template-dir")) args))
                             args'               (if (and (= "create" (first args))
                                                          default-dir
                                                          (not user-set?))
                                                   (concat ["create" "--template-dir" default-dir] (rest args))
                                                   args)]
                         (apply c3kit-jig.main/-main args'))}
  test       {:doc      "Run all tests"
              :requires ([speclj.cli])
              :task     (speclj.cli/run "-c" "spec")}
  build      {:doc      "Build cli/dist/c3kit-jig.bb (bakes root VERSION)"
              :requires ([babashka.fs :as fs]
                         [clojure.string :as str])
              :task     (let [out     "dist/c3kit-jig.bb"
                              version (str/trim (slurp "../VERSION"))]
                          (fs/create-dirs "dist")
                          (fs/delete-if-exists out)
                          (shell "bb" "uberscript" out "-m" "c3kit-jig.main")
                          (let [baked (str/replace (slurp out) "0.0.0-DEV" version)]
                            (spit out (str "#!/usr/bin/env bb\n" baked)))
                          (fs/set-posix-file-permissions out "rwxr-xr-x")
                          (println (str "built dist/c3kit-jig.bb @ " version)))}
  lint       {:doc  "Run clj-kondo"
              :task (shell "clj-kondo" "--lint" "src" "spec")}
  install    {:doc     "Build CLI from local source and install it via install.sh (same path users use)"
              :depends [build]
              :task    (let [bb-file (.getAbsolutePath (clojure.java.io/file "dist/c3kit-jig.bb"))]
                         (shell {:extra-env {"C3KIT_LOCAL_BB" bb-file}}
                                "bash" "install.sh"))}
  release    {:doc      "Tag root VERSION as a release and push (CI builds + publishes)"
              :requires ([c3kit-jig.release :as release]
                         [clojure.string :as str])
              :task     (let [version  (str/trim (slurp "../VERSION"))
                              changes  (slurp "../CHANGES.md")
                              dirty?   (-> (shell {:out :string} "git" "status" "--short")
                                           :out str/blank? not)
                              tag?     (-> (shell {:out :string :err :string :continue true}
                                                  "git" "rev-parse" "--verify" "--quiet"
                                                  (str "refs/tags/" version))
                                           :exit zero?)
                              blockers (release/release-blockers
                                        {:version version :changes changes
                                         :dirty? dirty? :tag-exists? tag?})]
                          (if (seq blockers)
                            (do (doseq [b blockers] (println "ERROR:" b))
                                (System/exit 1))
                            (do (shell "git" "tag" version)
                                (shell "git" "push" "origin" version)
                                (println (str "tagged + pushed " version
                                              " — CI will build and publish assets")))))}}}
